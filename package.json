{
  "name": "@dativa-lv/lx-builders",
  "description": "LX/UI Builders",
  "prettier": "@zzdats/prettier-config",
  "files": [
    "dist",
    "dist/vite",
    "dist/styles"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dativa-lv/lx-builders/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dativa-lv/lx-builders.git"
  },
  "homepage": "https://lx-ui.dev/",
  "main": "./dist/dativa-lx-builders.umd.js",
  "typings": "./dist/dativa-lx-builders.d.ts",
  "module": "./dist/dativa-lx-builders.esm.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/dativa-lx-builders.esm.js",
      "require": "./dist/dativa-lx-builders.umd.js",
      "types": "./dist/dativa-lx-builders.d.ts"
    },
    "./vite": {
      "import": "./dist/vite/dativa-lx-builders-vite.es.js",
      "types": "./dist/vite/types/index.d.ts"
    },
    "./dist/styles/*": "./dist/styles/*"
  },
  "packageManager": "bun@1.3.14",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite --host",
    "build:lib": "bun vite build --mode lib",
    "build:css": "bun vite build --mode css",
    "build": "bun run build:lib && bun run build:css",
    "preview": "bun vite preview --mode lib",
    "lint": "eslint .",
    "test": "bun vitest --mode lib"
  },
  "dependencies": {
    "@vue/test-utils": "^2.4.3",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "@vueuse/components": "14.0.0",
    "@vueuse/core": "14.0.0",
    "@vueuse/integrations": "14.0.0",
    "@dativa-lv/lx-ui": "2.2.10"
  },
  "devDependencies": {
    "@testing-library/vue": "^8.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-airbnb": "8.0.0",
    "@zzdats/prettier-config": "^1.0.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-vue": "^9.20.1",
    "eslint-plugin-vuejs-accessibility": "^2.4.1",
    "happy-dom": "^20.8.9",
    "jest": "^29.7.0",
    "prettier": "^2.8.8",
    "regenerator-runtime": "^0.14.1",
    "vite": "8.0.16",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.0",
    "vue": "^3.5.17",
    "ajv": "^8.5.0"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "minimatch": "10.2.3",
    "js-cookie": "3.0.7",
    "flatted": "3.4.2",
    "postcss": "8.5.10",
    "markdown-it": "14.2.0",
    "picomatch": "2.3.2",
    "js-yaml": "3.14.2",
    "axios": "1.16.0"
  },
  "peerDependencies": {
    "vue": "^3.5.17",
    "@dativa-lv/lx-ui": "2.2.10"
  }
}
